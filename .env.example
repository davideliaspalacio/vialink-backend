# ============================================
# Vialink Backend — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://vialink.vercel.app

# --- Database (Supabase Postgres + PostGIS) ---
# Use Connection Pooler URL for runtime (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public
# Use Direct Connection for Prisma migrations (port 5432)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?schema=public

# --- Supabase API ---
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=

# --- Anthropic (Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Walking paths provider (Mapbox) ---
MAPBOX_ACCESS_TOKEN=pk.eyJ1...
# Alternative (uncomment if using ORS instead):
# OPENROUTESERVICE_API_KEY=

# --- Simulator ---
SIMULATOR_DEFAULT_AGENTS=500
SIMULATOR_LLM_PROBABILITY=0.10
SIMULATOR_TICK_MS=1000
SIMULATOR_BUS_TICK_MS=3000

# --- Rate limiting ---
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
ASSISTANT_THROTTLE_LIMIT=5
